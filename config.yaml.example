# =============================================================================
# config.yaml — Configuração do Sistema de Correção Automática
# =============================================================================
# INSTRUÇÕES:
#   cp config.yaml.example config.yaml
#   Edite config.yaml com suas credenciais reais.
#   NUNCA versione o config.yaml (adicione ao .gitignore).
# =============================================================================

# --- Configuração de E-mail (SMTP) ---
email:
  smtp_server: smtp.ufabc.edu.br
  smtp_port: 587
  from_address: seu_email@ufabc.edu.br
  password: "SUA_SENHA_AQUI"
  use_tls: true

templates:
  assunto: "Rubricas e Correções geradas por LLM - Prova - {login}@aluno.ufabc.edu.br"
  corpo: |
    Prezado(a) {nome_pasta},

    A sua nota da prova já está disponível no Moodle.
    Abaixo, envio as competências avaliadas e uma correção detalhada gerada por IA.
    
    [O restante do seu template de e-mail deve ser mantido aqui para manter o padrão da mensagem]

# --- Provedor de LLM ativo ---
# Valores aceitos: "groq" | "deepseek" | "gemini"
llm:
  provider: "deepseek" 

# --- Configuração da API Groq ---
# Obtenha sua chave em: https://console.groq.com/keys
groq:
  api_url: "https://api.groq.com/openai/v1/chat/completions"
  api_key: "SUA_CHAVE_GROQ_AQUI"
  temperature: 0.7
  max_response_chars: 8192
  min_response_chars: 5
  models:
    - "llama-3.3-70b-versatile"
    # - "llama-3.3-70b-versatile"
    # - "openai/gpt-oss-120b"
    # - "llama-3.1-8b-instant"

# --- Configuração da API DeepSeek ---
# Obtenha sua chave em: https://platform.deepseek.com/api_keys
deepseek:
  api_url: "https://api.deepseek.com/v1/chat/completions"
  api_key: "SUA_CHAVE_DEEPSEEK_AQUI"
  temperature: 0.3
  max_response_chars: 8000
  min_response_chars: 5
  models:
    - "deepseek-chat"
    # - "deepseek-coder"
    # - "deepseek-reasoner"

# --- Configuração da API Gemini ---
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
gemini:
  api_key: "SUA_CHAVE_GEMINI_AQUI"
  temperature: 0.3
  timeout: 60
  models:
    - "gemini-2.0-flash" 

#MODELS=("gemini-2.5-flash" "gemini-2.5-pro" "gemini-2.0-flash-001" "gemini-2.0-flash-lite-001")

# --- Configuração do Processamento de Provas ---
grading:
  # Arquivo de prompt universal (contém as rubricas de todos os tipos).
  prompt_file: "promptP3.txt"
  weights:
    q1: 50
    q2: 50
  use_llm: true                  
  min_code_lines: 4              
  supported_extensions:          
    - py
    - java
    - c
    - cpp

# --- Configuração de Pastas ---
paths:
  student_base_dir: "p3moodle"
  output_rubric_filename: "rubrica.txt"